# Tells Cloudflare which files in the repo root are NOT part of the actual
# website, so it doesn't try to upload them as static assets. node_modules
# alone was 122 MiB (over Cloudflare's 25 MiB single-file limit) and has
# nothing to do with the site itself - it's just installed packages needed
# to run the build script in GitHub Actions.
node_modules
.git
.github
scripts
supabase
package.json
package-lock.json
wrangler.toml
worker.js
.assetsignore
